# 服务基础配置
LISTEN_HOST=0.0.0.0
SERVER_PORT=58081
XQM_PARAM=XQM
TOKEN_HEADER=X-Api-Token

# 鉴权密钥（部署时替换为自己的随机字符串）
VALID_TOKEN=自定义长随机Token
LOG_PAGE_SECRET=日志页面访问密钥

# MySQL数据库配置
MYSQL_HOST=数据库地址
MYSQL_PORT=3306
MYSQL_USER=数据库账号
MYSQL_PASSWORD=数据库密码
MYSQL_DB=数据库名
MYSQL_CHARSET=utf8mb4

# 安全限制配置
SECURITY_ONLY_SELECT=True
SECURITY_MAX_ROWS=5000
RATE_LIMIT_SECONDS=1